{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "public benchmark repository/schemas/model-pilot-v0.1.schema.json",
  "title": "LeanNumBench model pilot manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "pilot_id",
    "description",
    "intended_use",
    "tasks",
    "selection_policy",
    "records"
  ],
  "properties": {
    "schema_version": {
      "const": "0.1.0"
    },
    "pilot_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+([._-][a-z0-9]+)*$"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "intended_use": {
      "type": "string",
      "minLength": 1
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "statement_translation",
          "proof_completion",
          "theorem_retrieval"
        ]
      },
      "uniqueItems": true
    },
    "selection_policy": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "prompt_options": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source_declaration_context": {
          "type": "string",
          "enum": [
            "full",
            "none"
          ],
          "default": "full"
        }
      }
    },
    "records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "record_id",
          "role",
          "rationale"
        ],
        "properties": {
          "record_id": {
            "type": "string",
            "pattern": "^[a-z0-9]+([._-][a-z0-9]+)*$"
          },
          "role": {
            "type": "string",
            "minLength": 1
          },
          "rationale": {
            "type": "string",
            "minLength": 1
          },
          "task_overrides": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "statement_translation",
                "proof_completion",
                "theorem_retrieval"
              ]
            },
            "uniqueItems": true
          }
        }
      }
    }
  }
}
